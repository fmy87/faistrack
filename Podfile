platform :ios, '15.0'
use_frameworks!

project 'FaisTrack.xcodeproj'

target 'FaisTrack' do
  # Firebase Core
  pod 'Firebase/Auth'
  pod 'Firebase/Firestore'
  pod 'Firebase/Messaging'

  # Google Sign In
  pod 'GoogleSignIn'

  # Maps: using Apple's native MapKit instead of Google Maps SDK,
  # so no Maps-related pods or API keys are required.
end
